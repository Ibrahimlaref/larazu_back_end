# Production Environment Variables for Render.com

# Django
DEBUG=false
SECRET_KEY=your-production-secret-key-here
DJANGO_SETTINGS_MODULE=brahim.settings.prod

# Database (provided by Render PostgreSQL)
POSTGRES_DB=lazuli
POSTGRES_USER=lazuli
POSTGRES_PASSWORD=your-render-db-password
POSTGRES_HOST=your-render-db-host
POSTGRES_PORT=5432

# Redis (provided by Render Redis)
REDIS_URL=redis://your-render-redis-host:6379

# CORS
ALLOWED_HOSTS=your-backend-url.onrender.com
CORS_ALLOWED_ORIGINS=https://your-frontend-url.onrender.com

# LAZULI Admin
LAZULI_ADMIN_TOKEN=your-production-admin-token

# Celery
CELERY_BROKER_URL=redis://your-render-redis-host:6379/0
CELERY_RESULT_BACKEND=redis://your-render-redis-host:6379/0